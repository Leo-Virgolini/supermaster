# ============================================================================
# .gitignore raíz del monorepo supermaster.
# Cada subproyecto tiene su propio .gitignore que aplica dentro de su carpeta;
# estas reglas son defensivas a nivel global.
# ============================================================================

# -- Variables de entorno y configuración con secretos --------------------
.env
.env.*
!.env.example
!.env.*.example
*.env.local

# -- Credenciales, claves, certificados ----------------------------------
secrets/
*.pem
*.key
*.p8
*.p12
*.pfx
*.jks
*.keystore
*.truststore
*.crt
*.cer
*.csr
*.der
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.gpg
*.asc
credentials.json
client_secret*.json
service-account*.json
firebase-adminsdk*.json
auth.json
.npmrc
.netrc
.pgpass

# -- Archivos típicos donde se filtran secretos --------------------------
*secret*
*secrets*
!*Secrets.java
!*Secret.java
!*Secrets.kt
!*Secret.kt
!*secret*.example
!*secrets*.example

# -- Logs y dumps que pueden contener datos sensibles --------------------
*.log
logs/
*.sql.gz
*.dump
*.bak

# -- Build / dependencias (también cubierto por subproyectos) ------------
node_modules/
target/
build/
dist/
out/
.next/
*.tsbuildinfo

# -- IDEs y herramientas --------------------------------------------------
.idea/
.vscode/
*.iml
*.iws
*.ipr
.claude/
.cursor/

# -- Deploy ---------------------------------------------------------------
deploy/.env
deploy/.env.deploy

# -- Logs y backups del runtime (montados como volúmenes en docker) ------
/logs/
/backups/

# -- Superpowers (andamiaje del flujo de skills, no código) --------------
.superpowers/
docs/superpowers/

# -- OS -------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
