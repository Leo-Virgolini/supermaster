# ==============================================================================
# .env.deploy.example — config para update-remote.ps1 (deploy SSH al servidor)
# ==============================================================================
# Copiar como .env.deploy y completar. NO se sube al repo (ver .gitignore).

# Destino SSH: usuario@host (IP o dominio del servidor).
REMOTE_SSH=leo@TU_SERVIDOR

# Puerto SSH (default 22).
REMOTE_PORT=22

# (Opcional) Ruta a tu clave privada SSH en Windows. Si usás el agente SSH
# o la clave por defecto (~/.ssh/id_*), podés dejarlo vacío/comentado.
#REMOTE_KEY=C:/Users/Leo/.ssh/id_ed25519

# Ruta en el SERVIDOR donde está clonado el repo supermaster.
REMOTE_REPO_DIR=/data/supermaster/repo

# Rama a desplegar.
GIT_BRANCH=main

# Ruta al compose de prod, relativa a REMOTE_REPO_DIR.
COMPOSE_FILE=deploy/docker-compose.prod.yml

# Ruta al archivo .env con las credenciales (DB_PASSWORD, DB_USERNAME, ...) en el
# SERVIDOR, relativa a REMOTE_REPO_DIR. docker compose lo lee con --env-file.
# Este archivo vive SOLO en el server, nunca en el repo.
REMOTE_ENV_FILE=deploy/.env
