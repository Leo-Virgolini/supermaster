# ==============================================
# Configuracion de despliegue - SuperMaster
# ==============================================
# Copiar este archivo como .env y ajustar valores

# Base de datos MySQL
DB_USERNAME=root
DB_PASSWORD=CAMBIAR_AQUI

# Ruta al directorio de secretos en el HOST
SECRETS_DIR=C:/ProgramData/SuperMaster/secrets

# Ruta al directorio de imagenes en el HOST
IMAGENES_DIR=D:/Doc. Compartidos/IMAGENES

# Ruta raiz para salida de catalogos PDF en el HOST
CATALOGOS_DIR=G:/Mi unidad

# Ruta a logs persistentes del backend en el HOST.
# Relativo a deploy/docker-compose.yml — por defecto va a la raíz del repo.
LOGS_DIR=../logs

# Ruta donde guardar los backups diarios de MySQL.
# Relativo a deploy/docker-compose.yml — por defecto va a la raíz del repo.
BACKUPS_DIR=../backups

# (Opcionales) Override de los paths de build dentro del repo.
# Por defecto se usan ../supermaster-backend y ../supermaster-frontend
# relativos a deploy/docker-compose.yml — no hace falta tocarlos.
#BACKEND_PATH=../supermaster-backend
#FRONTEND_PATH=../supermaster-frontend

# Rama del monorepo desde donde se hace pull
GIT_BRANCH=main

# JWT expiracion en ms (12 horas = 43200000)
JWT_EXPIRATION=43200000
