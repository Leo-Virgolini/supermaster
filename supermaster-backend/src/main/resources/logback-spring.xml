<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Replicar config de application.properties -->
    <property name="LOG_PATTERN_CONSOLE" value="%d{yyyy-MM-dd HH:mm:ss} - %msg%n"/>
    <property name="LOG_PATTERN_FILE" value="%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- Consola -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN_CONSOLE}</pattern>
        </encoder>
    </appender>

    <!-- Log general de la aplicacion -->
    <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>10</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN_FILE}</pattern>
        </encoder>
    </appender>

    <!-- Log separado para automatizacion de precios (rolling diario, 7 dias) -->
    <appender name="AUTOMATIZACION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/automatizacion-precios.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/automatizacion-precios.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Logger dedicado: va a su archivo + al general -->
    <logger name="ar.com.leo.super_master_backend.dominio.automatizacion_precios" level="INFO" additivity="true">
        <appender-ref ref="AUTOMATIZACION_FILE"/>
    </logger>

    <!-- Root: WARN para el paquete de la app (como estaba en application.properties) -->
    <logger name="ar.com.leo.super_master_backend" level="WARN"/>

    <!-- Recálculo de precios por canal: INFO para ver progreso -->
    <logger name="ar.com.leo.super_master_backend.dominio.canal.service.CanalConceptoCuotaServiceImpl" level="INFO"/>
    <logger name="ar.com.leo.super_master_backend.dominio.producto.calculo.service" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP_FILE"/>
    </root>
</configuration>
